<script setup lang="ts">
import { computed, onMounted, reactive, ref } from 'vue'
import request from '../utils/request'

interface PublicTreeConfig {
  title: string
  subtitle: string
  description: string
}

interface PublicTreeNode {
  id: number
  name: string
  role: string
  generation: number
  description: string
  sort: number
  status: number
}

interface PublicTreeRelationship {
  id: number
  from_node_id: number
  to_node_id: number
  relation_type: string
  relation_name: string
  remark: string
  sort: number
  status: number
}

interface PublicTreeResult {
  config: PublicTreeConfig
  nodes: PublicTreeNode[]
  relationships: PublicTreeRelationship[]
  generation_keys: number[]
  generations: Record<string, PublicTreeNode[]>
}

interface PositionedNode extends PublicTreeNode {
  x: number
  y: number
  kind: string
}

interface LineItem {
  id: string
  path: string
  label: string
  labelX: number
  labelY: number
  type: string
}

const loading = ref(false)

const tree = reactive<PublicTreeResult>({
  config: {
    title: '',
    subtitle: '',
    description: ''
  },
  nodes: [],
  relationships: [],
  generation_keys: [],
  generations: {}
})

const cardW = 292
const cardH = 146
const coreW = 340
const coreH = 174

const board = computed(() => {
  const count = Math.max(tree.nodes.length, 6)

  return {
    width: Math.max(1180, count * 138),
    height: count > 8 ? 860 : 760
  }
})

const center = computed(() => {
  return {
    x: board.value.width / 2,
    y: board.value.height / 2
  }
})

const displayTitle = computed(() => {
  return tree.config.title || '汉武帝重要亲属关系示意'
})

const displayDescription = computed(() => {
  return tree.config.description || '本关系树仅用于官网公开展示，不读取用户真实家庭树数据。'
})

const coreNode = computed(() => {
  return findCoreNode(tree.nodes)
})

const positionedNodes = computed<PositionedNode[]>(() => {
  if (!tree.nodes.length) return []

  const core = coreNode.value || tree.nodes[0]
  const others = tree.nodes
    .filter((node) => node.id !== core.id)
    .sort((a, b) => {
      if (a.generation !== b.generation) return a.generation - b.generation
      return Number(a.sort || 0) - Number(b.sort || 0)
    })

  const result: PositionedNode[] = [
    {
      ...core,
      x: center.value.x - coreW / 2,
      y: center.value.y - coreH / 2,
      kind: 'core'
    }
  ]

  const slots = buildSlots(others.length)

  others.forEach((node, index) => {
    const slot = slots[index]
    const kind = getNodeKind(node, core)

    result.push({
      ...node,
      x: slot.x - cardW / 2,
      y: slot.y - cardH / 2,
      kind
    })
  })

  return result
})

const lines = computed<LineItem[]>(() => {
  const map = new Map<number, PositionedNode>()

  positionedNodes.value.forEach((node) => {
    map.set(node.id, node)
  })

  return tree.relationships
    .map((rel, index) => {
      const from = map.get(rel.from_node_id)
      const to = map.get(rel.to_node_id)

      if (!from || !to) return null

      const start = edgePoint(from, to)
      const end = edgePoint(to, from)
      const midX = (start.x + end.x) / 2
      const midY = (start.y + end.y) / 2

      const curveOffset = index % 2 === 0 ? -28 : 28
      const path = [
        'M', start.x, start.y,
        'C', midX, start.y + curveOffset,
        midX, end.y - curveOffset,
        end.x, end.y
      ].join(' ')

      return {
        id: String(rel.id || index),
        path,
        label: rel.relation_name || rel.relation_type,
        labelX: midX,
        labelY: midY,
        type: safeClass(rel.relation_type)
      }
    })
    .filter((item): item is LineItem => Boolean(item))
})

onMounted(load)

async function load() {
  loading.value = true

  const endpoints = [
    '/web/family/tree',
    '/web/public-tree',
    '/web/family-tree',
    '/public-tree',
    '/family/tree'
  ]

  try {
    let loaded = false

    for (const url of endpoints) {
      try {
        const raw = await request.get(url) as any
        const payload = normalizeTreePayload(raw)

        if (payload && Array.isArray(payload.nodes)) {
          applyTreePayload(payload)
          loaded = true
          break
        }
      } catch {
        // 尝试下一个兼容地址
      }
    }

    if (!loaded) {
      tree.nodes = []
      tree.relationships = []
    }
  } finally {
    loading.value = false
  }
}

function normalizeTreePayload(raw: any): any {
  if (!raw) return null

  const candidates = [
    raw,
    raw.data,
    raw.data?.data,
    raw.result,
    raw.result?.data,
    raw.payload,
    raw.payload?.data
  ]

  for (const item of candidates) {
    if (!item) continue

    const nodes =
      item.nodes ||
      item.node_list ||
      item.public_tree_nodes ||
      item.publicTreeNodes ||
      []

    const relationships =
      item.relationships ||
      item.relations ||
      item.relationship_list ||
      item.public_tree_relationships ||
      item.publicTreeRelationships ||
      []

    if (Array.isArray(nodes)) {
      return {
        config: item.config || item.tree_config || item.public_tree_config || tree.config,
        nodes,
        relationships: Array.isArray(relationships) ? relationships : [],
        generation_keys: item.generation_keys || item.generationKeys || [],
        generations: item.generations || {}
      }
    }
  }

  return null
}

function applyTreePayload(payload: any) {
  tree.config = {
    title: payload.config?.title || tree.config.title,
    subtitle: payload.config?.subtitle || tree.config.subtitle,
    description: payload.config?.description || tree.config.description
  }

  tree.nodes = Array.isArray(payload.nodes) ? payload.nodes : []
  tree.relationships = Array.isArray(payload.relationships) ? payload.relationships : []
  tree.generation_keys = Array.isArray(payload.generation_keys) ? payload.generation_keys : []
  tree.generations = payload.generations || {}
}

function buildSlots(count: number) {
  const points: Array<{ x: number; y: number }> = []
  const cx = center.value.x
  const cy = center.value.y

  const primary = [
    { x: cx, y: cy - 270 },
    { x: cx + 385, y: cy - 160 },
    { x: cx + 385, y: cy + 160 },
    { x: cx, y: cy + 270 },
    { x: cx - 385, y: cy + 160 },
    { x: cx - 385, y: cy - 160 }
  ]

  points.push(...primary)

  if (count > primary.length) {
    const extra = count - primary.length
    const radiusX = 520
    const radiusY = 330

    for (let i = 0; i < extra; i++) {
      const angle = -Math.PI / 2 + ((Math.PI * 2) / extra) * i + Math.PI / 8
      points.push({
        x: cx + Math.cos(angle) * radiusX,
        y: cy + Math.sin(angle) * radiusY
      })
    }
  }

  return points.slice(0, count)
}

function findCoreNode(nodes: PublicTreeNode[]) {
  if (!nodes.length) return null

  const exact = nodes.find((node) => node.name.includes('汉武帝') || node.name.includes('刘彻'))
  if (exact) return exact

  const roleCore = nodes.find((node) => {
    return node.role.includes('核心') || node.role.includes('中心')
  })

  if (roleCore) return roleCore

  const sorted = nodes
    .map((node) => {
      const count = tree.relationships.filter((rel) => {
        return rel.from_node_id === node.id || rel.to_node_id === node.id
      }).length

      return { node, count }
    })
    .sort((a, b) => b.count - a.count)

  return sorted[0]?.node || nodes[0]
}

function getNodeKind(node: PublicTreeNode, core: PublicTreeNode) {
  const directRelations = tree.relationships.filter((rel) => {
    return rel.from_node_id === node.id ||
      rel.to_node_id === node.id
  })

  if (directRelations.some((rel) => rel.relation_type === 'spouse')) return 'spouse'
  if (directRelations.some((rel) => rel.relation_type === 'in_law')) return 'relative'
  if (directRelations.some((rel) => rel.relation_type === 'uncle_nephew')) return 'relative'

  if (node.generation < core.generation) return 'elder'
  if (node.generation > core.generation) return 'child'

  return 'relative'
}

function edgePoint(from: PositionedNode, to: PositionedNode) {
  const fromW = from.kind === 'core' ? coreW : cardW
  const fromH = from.kind === 'core' ? coreH : cardH
  const toW = to.kind === 'core' ? coreW : cardW
  const toH = to.kind === 'core' ? coreH : cardH

  const fromCenterX = from.x + fromW / 2
  const fromCenterY = from.y + fromH / 2
  const toCenterX = to.x + toW / 2
  const toCenterY = to.y + toH / 2

  const dx = toCenterX - fromCenterX
  const dy = toCenterY - fromCenterY

  if (Math.abs(dx) > Math.abs(dy)) {
    return {
      x: dx > 0 ? from.x + fromW : from.x,
      y: fromCenterY
    }
  }

  return {
    x: fromCenterX,
    y: dy > 0 ? from.y + fromH : from.y
  }
}

function relatedText(nodeId: number) {
  return tree.relationships
    .filter((rel) => rel.from_node_id === nodeId || rel.to_node_id === nodeId)
    .slice(0, 2)
    .map((rel) => {
      const otherId = rel.from_node_id === nodeId ? rel.to_node_id : rel.from_node_id
      return (rel.relation_name || rel.relation_type) + '：' + nodeName(otherId)
    })
}

function nodeName(id: number) {
  return tree.nodes.find((item) => item.id === id)?.name || '-'
}

function firstChar(name: string) {
  return name ? name.slice(0, 1) : '?'
}

function safeClass(value: string) {
  return value.replace(/[^a-zA-Z0-9_-]/g, '')
}
</script>

