<script setup lang="ts">
import { computed, onMounted, reactive, ref } from 'vue'
import request from '../utils/request'

interface PublicTreeConfig {
  title: string
  subtitle: string
  description: string
}

interface PublicTreeNode {
  id: number
  name: string
  role: string
  generation: number
  description: string
  sort: number
  status: number
}

interface PublicTreeRelationship {
  id: number
  from_node_id: number
  to_node_id: number
  relation_type: string
  relation_name: string
  remark: string
  sort: number
  status: number
}

interface PublicTreeResult {
  config: PublicTreeConfig
  nodes: PublicTreeNode[]
  relationships: PublicTreeRelationship[]
  generation_keys: number[]
  generations: Record<string, PublicTreeNode[]>
}

interface PositionedNode extends PublicTreeNode {
  x: number
  y: number
  w: number
  h: number
  kind: string
}

interface LineItem {
  id: string
  path: string
  label: string
  labelX: number
  labelY: number
  type: string
}

const loading = ref(false)

const tree = reactive<PublicTreeResult>({
  config: {
    title: '',
    subtitle: '',
    description: ''
  },
  nodes: [],
  relationships: [],
  generation_keys: [],
  generations: {}
})

const board = computed(() => {
  const count = Math.max(tree.nodes.length, 6)

  return {
    width: Math.max(1280, count * 135),
    height: count > 8 ? 900 : 760
  }
})

const displayTitle = computed(() => {
  return tree.config.title || '汉武帝重要亲属关系示意'
})

const displayDescription = computed(() => {
  return tree.config.description || '本关系树仅用于官网公开展示，不读取用户真实家庭树数据。'
})

const coreNode = computed(() => {
  return findCoreNode(tree.nodes)
})

const positionedNodes = computed<PositionedNode[]>(() => {
  const nodes = [...tree.nodes].sort((a, b) => {
    if (a.id === coreNode.value?.id) return -1
    if (b.id === coreNode.value?.id) return 1

    if (a.generation !== b.generation) return a.generation - b.generation

    return Number(b.sort || 0) - Number(a.sort || 0)
  })

  if (!nodes.length) return []

  const core = coreNode.value || nodes[0]
  const others = nodes.filter((item) => item.id !== core.id)

  const centerX = board.value.width / 2
  const centerY = board.value.height / 2

  const normalW = 250
  const normalH = 142
  const coreW = 330
  const coreH = 188

  const result: PositionedNode[] = [
    {
      ...core,
      x: centerX - coreW / 2,
      y: centerY - coreH / 2,
      w: coreW,
      h: coreH,
      kind: 'core'
    }
  ]

  const radiusX = Math.min(470, board.value.width / 2 - 190)
  const radiusY = board.value.height > 800 ? 310 : 245
  const total = Math.max(others.length, 1)

  others.forEach((node, index) => {
    const angle = -Math.PI / 2 + index * ((Math.PI * 2) / total)
    const x = centerX + Math.cos(angle) * radiusX - normalW / 2
    const y = centerY + Math.sin(angle) * radiusY - normalH / 2

    result.push({
      ...node,
      x: clamp(x, 36, board.value.width - normalW - 36),
      y: clamp(y, 42, board.value.height - normalH - 42),
      w: normalW,
      h: normalH,
      kind: nodeKind(node.id, core.id)
    })
  })

  return result
})

const lines = computed<LineItem[]>(() => {
  const map = new Map<number, PositionedNode>()

  positionedNodes.value.forEach((node) => {
    map.set(node.id, node)
  })

  return tree.relationships
    .map((rel, index) => {
      const from = map.get(rel.from_node_id)
      const to = map.get(rel.to_node_id)

      if (!from || !to) return null

      const start = edgePoint(from, to)
      const end = edgePoint(to, from)

      const midX = (start.x + end.x) / 2
      const midY = (start.y + end.y) / 2
      const offset = index % 2 === 0 ? -28 : 28

      const path = [
        'M', start.x, start.y,
        'C', midX, start.y + offset,
        midX, end.y - offset,
        end.x, end.y
      ].join(' ')

      return {
        id: String(rel.id || index),
        path,
        label: rel.relation_name || rel.relation_type,
        labelX: midX,
        labelY: midY,
        type: safeClass(rel.relation_type)
      }
    })
    .filter((item): item is LineItem => Boolean(item))
})

onMounted(load)

async function load() {
  loading.value = true

  try {
    const res = await request.get('/web/family/tree') as PublicTreeResult
    Object.assign(tree, res)
  } finally {
    loading.value = false
  }
}

function findCoreNode(nodes: PublicTreeNode[]) {
  if (!nodes.length) return null

  const roleCore = nodes.find((node) => {
    return node.role.includes('核心') || node.role.toLowerCase().includes('core')
  })

  if (roleCore) return roleCore

  const sorted = nodes
    .map((node) => {
      const count = tree.relationships.filter((rel) => {
        return rel.from_node_id === node.id || rel.to_node_id === node.id
      }).length

      return {
        node,
        count
      }
    })
    .sort((a, b) => b.count - a.count)

  return sorted[0]?.node || nodes[0]
}

function nodeKind(nodeId: number, coreId: number) {
  const related = tree.relationships.filter((rel) => {
    return rel.from_node_id === nodeId ||
      rel.to_node_id === nodeId ||
      rel.from_node_id === coreId ||
      rel.to_node_id === coreId
  })

  if (related.some((rel) => rel.relation_type === 'spouse')) return 'spouse'
  if (related.some((rel) => rel.relation_type === 'in_law')) return 'inlaw'
  if (related.some((rel) => rel.relation_type === 'uncle_nephew')) return 'relative'

  const node = tree.nodes.find((item) => item.id === nodeId)
  const core = tree.nodes.find((item) => item.id === coreId)

  if (node && core) {
    if (node.generation < core.generation) return 'elder'
    if (node.generation > core.generation) return 'child'
  }

  return 'relative'
}

function edgePoint(from: PositionedNode, to: PositionedNode) {
  const fromCenterX = from.x + from.w / 2
  const fromCenterY = from.y + from.h / 2
  const toCenterX = to.x + to.w / 2
  const toCenterY = to.y + to.h / 2

  const dx = toCenterX - fromCenterX
  const dy = toCenterY - fromCenterY

  if (Math.abs(dx) > Math.abs(dy)) {
    return {
      x: dx > 0 ? from.x + from.w : from.x,
      y: fromCenterY
    }
  }

  return {
    x: fromCenterX,
    y: dy > 0 ? from.y + from.h : from.y
  }
}

function relatedText(nodeId: number) {
  return tree.relationships
    .filter((rel) => rel.from_node_id === nodeId || rel.to_node_id === nodeId)
    .slice(0, 2)
    .map((rel) => {
      const otherId = rel.from_node_id === nodeId ? rel.to_node_id : rel.from_node_id
      return (rel.relation_name || rel.relation_type) + '：' + nodeName(otherId)
    })
}

function nodeName(id: number) {
  return tree.nodes.find((item) => item.id === id)?.name || '-'
}

function firstChar(name: string) {
  return name ? name.slice(0, 1) : '?'
}

function safeClass(value: string) {
  return value.replace(/[^a-zA-Z0-9_-]/g, '')
}

function clamp(value: number, min: number, max: number) {
  return Math.max(min, Math.min(max, value))
}
