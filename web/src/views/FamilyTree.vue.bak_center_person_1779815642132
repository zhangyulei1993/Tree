<script setup lang="ts">
import { computed, onMounted, reactive, ref } from 'vue'
import request from '../utils/request'

interface PublicTreeConfig {
  title: string
  subtitle: string
  description: string
}

interface PublicTreeNode {
  id: number
  name: string
  role: string
  generation: number
  description: string
  sort: number
  status: number
}

interface PublicTreeRelationship {
  id: number
  from_node_id: number
  to_node_id: number
  relation_type: string
  relation_name: string
  remark: string
  sort: number
  status: number
}

interface PublicTreeResult {
  config: PublicTreeConfig
  nodes: PublicTreeNode[]
  relationships: PublicTreeRelationship[]
  generation_keys: number[]
  generations: Record<string, PublicTreeNode[]>
}

interface PositionedNode extends PublicTreeNode {
  x: number
  y: number
}

interface GenerationGroup {
  generation: number
  x: number
}

interface LineItem {
  id: string
  path: string
  label: string
  labelX: number
  labelY: number
  type: string
}

const loading = ref(false)

const tree = reactive<PublicTreeResult>({
  config: {
    title: '',
    subtitle: '',
    description: ''
  },
  nodes: [],
  relationships: [],
  generation_keys: [],
  generations: {}
})

const cardW = 300
const cardH = 142
const columnGap = 360
const rowGap = 176

const displayTitle = computed(() => {
  return tree.config.title || '汉武帝重要亲属关系示意'
})

const displayDescription = computed(() => {
  return tree.config.description || '本关系树仅用于官网公开展示，不读取用户真实家庭树数据。'
})

const coreNode = computed(() => {
  return findCoreNode(tree.nodes)
})

const generationKeys = computed(() => {
  if (tree.generation_keys && tree.generation_keys.length) {
    return [...tree.generation_keys].sort((a, b) => a - b)
  }

  const set = new Set<number>()

  tree.nodes.forEach((node) => {
    set.add(Number(node.generation || 1))
  })

  return Array.from(set).sort((a, b) => a - b)
})

const board = computed(() => {
  const maxRows = Math.max(1, ...generationKeys.value.map((key) => nodesByGeneration(key).length))
  const cols = Math.max(1, generationKeys.value.length)

  return {
    width: Math.max(1080, cols * columnGap + 80),
    height: Math.max(620, maxRows * rowGap + 130)
  }
})

const generationGroups = computed<GenerationGroup[]>(() => {
  return generationKeys.value.map((generation, index) => {
    return {
      generation,
      x: 40 + index * columnGap
    }
  })
})

const positionedNodes = computed<PositionedNode[]>(() => {
  const result: PositionedNode[] = []

  generationKeys.value.forEach((generation, columnIndex) => {
    const list = nodesByGeneration(generation)
    const totalHeight = list.length * cardH + Math.max(0, list.length - 1) * (rowGap - cardH)
    const startY = Math.max(90, (board.value.height - totalHeight) / 2 + 28)

    list.forEach((node, rowIndex) => {
      result.push({
        ...node,
        x: 40 + columnIndex * columnGap,
        y: startY + rowIndex * rowGap
      })
    })
  })

  return result
})

const lines = computed<LineItem[]>(() => {
  const map = new Map<number, PositionedNode>()

  positionedNodes.value.forEach((node) => {
    map.set(node.id, node)
  })

  return tree.relationships
    .map((rel, index) => {
      const from = map.get(rel.from_node_id)
      const to = map.get(rel.to_node_id)

      if (!from || !to) return null

      const start = edgePoint(from, to)
      const end = edgePoint(to, from)

      const midX = (start.x + end.x) / 2
      const midY = (start.y + end.y) / 2
      const lift = index % 2 === 0 ? -24 : 24

      const path = [
        'M', start.x, start.y,
        'C', midX, start.y + lift,
        midX, end.y - lift,
        end.x, end.y
      ].join(' ')

      return {
        id: String(rel.id || index),
        path,
        label: rel.relation_name || rel.relation_type,
        labelX: midX,
        labelY: midY,
        type: safeClass(rel.relation_type)
      }
    })
    .filter((item): item is LineItem => Boolean(item))
})

onMounted(load)

async function load() {
  loading.value = true

  const endpoints = [
    '/web/family/tree',
    '/web/public-tree',
    '/web/family-tree',
    '/public-tree',
    '/family/tree'
  ]

  try {
    let loaded = false

    for (const url of endpoints) {
      try {
        const raw = await request.get(url) as any
        const payload = normalizeTreePayload(raw)

        if (payload && Array.isArray(payload.nodes)) {
          applyTreePayload(payload)
          loaded = true
          break
        }
      } catch {
        // 尝试下一个兼容地址
      }
    }

    if (!loaded) {
      tree.nodes = []
      tree.relationships = []
    }
  } finally {
    loading.value = false
  }
}

function normalizeTreePayload(raw: any): any {
  if (!raw) return null

  const candidates = [
    raw,
    raw.data,
    raw.data?.data,
    raw.result,
    raw.result?.data,
    raw.payload,
    raw.payload?.data
  ]

  for (const item of candidates) {
    if (!item) continue

    const nodes =
      item.nodes ||
      item.node_list ||
      item.public_tree_nodes ||
      item.publicTreeNodes ||
      []

    const relationships =
      item.relationships ||
      item.relations ||
      item.relationship_list ||
      item.public_tree_relationships ||
      item.publicTreeRelationships ||
      []

    if (Array.isArray(nodes)) {
      return {
        config: item.config || item.tree_config || item.public_tree_config || tree.config,
        nodes,
        relationships: Array.isArray(relationships) ? relationships : [],
        generation_keys: item.generation_keys || item.generationKeys || [],
        generations: item.generations || {}
      }
    }
  }

  return null
}

function applyTreePayload(payload: any) {
  tree.config = {
    title: payload.config?.title || tree.config.title,
    subtitle: payload.config?.subtitle || tree.config.subtitle,
    description: payload.config?.description || tree.config.description
  }

  tree.nodes = Array.isArray(payload.nodes) ? payload.nodes : []
  tree.relationships = Array.isArray(payload.relationships) ? payload.relationships : []
  tree.generation_keys = Array.isArray(payload.generation_keys) ? payload.generation_keys : []
  tree.generations = payload.generations || {}
}

function nodesByGeneration(generation: number) {
  return tree.nodes
    .filter((node) => Number(node.generation || 1) === Number(generation))
    .sort((a, b) => {
      const coreId = coreNode.value?.id

      if (a.id === coreId) return -1
      if (b.id === coreId) return 1

      return Number(a.sort || 0) - Number(b.sort || 0)
    })
}

function findCoreNode(nodes: PublicTreeNode[]) {
  if (!nodes.length) return null

  const roleCore = nodes.find((node) => {
    return node.role.includes('核心') || node.name.includes('汉武帝')
  })

  if (roleCore) return roleCore

  const sorted = nodes
    .map((node) => {
      const count = tree.relationships.filter((rel) => {
        return rel.from_node_id === node.id || rel.to_node_id === node.id
      }).length

      return {
        node,
        count
      }
    })
    .sort((a, b) => b.count - a.count)

  return sorted[0]?.node || nodes[0]
}

function edgePoint(from: PositionedNode, to: PositionedNode) {
  const fromCenterX = from.x + cardW / 2
  const fromCenterY = from.y + cardH / 2
  const toCenterX = to.x + cardW / 2
  const toCenterY = to.y + cardH / 2

  const dx = toCenterX - fromCenterX
  const dy = toCenterY - fromCenterY

  if (Math.abs(dx) > Math.abs(dy)) {
    return {
      x: dx > 0 ? from.x + cardW : from.x,
      y: fromCenterY
    }
  }

  return {
    x: fromCenterX,
    y: dy > 0 ? from.y + cardH : from.y
  }
}

function relatedText(nodeId: number) {
  return tree.relationships
    .filter((rel) => rel.from_node_id === nodeId || rel.to_node_id === nodeId)
    .slice(0, 2)
    .map((rel) => {
      const otherId = rel.from_node_id === nodeId ? rel.to_node_id : rel.from_node_id
      return (rel.relation_name || rel.relation_type) + '：' + nodeName(otherId)
    })
}

function nodeName(id: number) {
  return tree.nodes.find((item) => item.id === id)?.name || '-'
}

function firstChar(name: string) {
  return name ? name.slice(0, 1) : '?'
}

function safeClass(value: string) {
  return value.replace(/[^a-zA-Z0-9_-]/g, '')
}
</script>

